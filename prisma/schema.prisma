generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Core financial tables
// ---------------------------------------------------------------------------

model Transaction {
  id             String   @id @default(uuid())
  date           DateTime
  amount         Float
  type           String   // income | expense | fee | payout | adjustment
  sourcePlatform String   @map("source_platform")
  category       String?
  description    String?
  rawSourceId    String?  @map("raw_source_id")
  rawData        String?  @map("raw_data") // JSON string of original row
  importId       String?  @map("import_id")
  import         Import?  @relation(fields: [importId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")

  // Manual entry support
  isManual Boolean @default(false) @map("is_manual")

  // Reconciliation: link L1 atomic event to L2 payout and L3 bank transaction
  linkedPayoutId          String?          @map("linked_payout_id")
  linkedPayout            Payout?          @relation(fields: [linkedPayoutId], references: [id])
  linkedBankTransactionId String?          @map("linked_bank_transaction_id")
  linkedBankTransaction   BankTransaction? @relation(fields: [linkedBankTransactionId], references: [id])
  reconciliationStatus    String           @default("unreconciled") @map("reconciliation_status")

  // Audit trail
  auditLogs AuditLog[]

  @@index([type, date])
  @@index([sourcePlatform, date])
  @@index([date])
  @@map("transactions")
}

model PlatformOrder {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  platform      String   // doordash | ubereats | grubhub | square
  orderDatetime DateTime @map("order_datetime")
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  deliveryFee   Float    @default(0) @map("delivery_fee")
  serviceFee    Float    @default(0) @map("service_fee")
  commissionFee Float    @default(0) @map("commission_fee")
  tip           Float    @default(0)
  netPayout     Float    @default(0) @map("net_payout")
  discounts     Float    @default(0)           // Square: discount amount; DD: customer discounts
  rawData       String?  @map("raw_data")
  importId      String?  @map("import_id")
  import        Import?  @relation(fields: [importId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  // Rich metadata from source platforms
  itemCategory    String?  @map("item_category")     // Square: Sweet Crêpes, Savory Crêpes, Drinks, etc.
  diningOption    String?  @map("dining_option")      // Square: For Here, To Go, Delivery, Pick Up
  channel         String?                             // DD: Marketplace/Storefront; GH: order_channel
  cardBrand       String?  @map("card_brand")         // Square: Visa, MasterCard, Amex, Gift Card
  fulfillmentType String?  @map("fulfillment_type")   // GH: delivery/pickup
  customerFees    Float    @default(0) @map("customer_fees")   // DD: customer fees
  marketingFees   Float    @default(0) @map("marketing_fees")  // DD/GH marketing costs
  refunds         Float    @default(0)                // UE: customer refunds
  adjustments     Float    @default(0)                // DD: error charges & adjustments

  // Reconciliation: link L1 order to L2 payout
  linkedPayoutId       String?  @map("linked_payout_id")
  linkedPayout         Payout?  @relation(fields: [linkedPayoutId], references: [id])
  reconciliationStatus String   @default("unreconciled") @map("reconciliation_status")

  @@unique([orderId, platform])
  @@index([platform, orderDatetime])
  @@index([orderDatetime])
  @@map("platform_orders")
}

model Vendor {
  id             String    @id @default(uuid())
  name           String    @unique
  displayName    String?   @map("display_name") // clean name from alias matching
  category       String?
  defaultAccount String?   @map("default_account")
  expenses       Expense[]
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("vendors")
}

model Expense {
  id            String   @id @default(uuid())
  vendorId      String?  @map("vendor_id")
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  amount        Float
  date          DateTime
  category      String?
  paymentMethod String?  @map("payment_method")
  notes         String?
  rawData       String?  @map("raw_data")
  importId      String?  @map("import_id")
  import        Import?  @relation(fields: [importId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  // Categorization
  expenseCategoryId String?          @map("expense_category_id")
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])

  @@index([vendorId, date])
  @@index([date])
  @@map("expenses")
}

model Payout {
  id                String           @id @default(uuid())
  platform          String
  payoutDate        DateTime         @map("payout_date")
  grossAmount       Float            @map("gross_amount")
  fees              Float            @default(0)
  netAmount         Float            @map("net_amount")
  bankTransactionId String?          @unique @map("bank_transaction_id")
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  rawData           String?          @map("raw_data")
  importId          String?          @map("import_id")
  import            Import?          @relation(fields: [importId], references: [id])
  createdAt         DateTime         @default(now()) @map("created_at")

  // Reconciliation: back-references from L1 + status
  transactions         Transaction[]
  platformOrders       PlatformOrder[]
  reconciliationStatus String   @default("unreconciled") @map("reconciliation_status")
  expectedAmount       Float?   @map("expected_amount")
  amountVariance       Float?   @map("amount_variance")

  @@map("payouts")
}

model BankTransaction {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  amount      Float
  category    String?
  reconciled  Boolean  @default(false)
  payout      Payout?

  // Rocket Money account info
  accountType   String?  @map("account_type")     // Cash, Credit Card, etc.
  accountName   String?  @map("account_name")     // BUS COMPLETE CHK, etc.
  institutionName String? @map("institution_name") // Chase, etc.
  taxDeductible Boolean  @default(false) @map("tax_deductible")
  tags          String?                            // comma-separated transaction tags
  rawData     String?  @map("raw_data")
  importId    String?  @map("import_id")
  import      Import?  @relation(fields: [importId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  // Reconciliation: back-references from L1 transactions + status
  linkedTransactions   Transaction[]
  reconciliationStatus String  @default("unreconciled") @map("reconciliation_status")

  @@index([date])
  @@map("bank_transactions")
}

// ---------------------------------------------------------------------------
// Reconciliation alerts
// ---------------------------------------------------------------------------

model ReconciliationAlert {
  id        String   @id @default(uuid())
  type      String   // payout_mismatch | deposit_mismatch | missing_payout | missing_deposit | duplicate_suspected
  severity  String   // info | warning | error
  platform  String?
  message   String
  details   String?  // JSON string with specifics

  payoutId          String?  @map("payout_id")
  bankTransactionId String?  @map("bank_transaction_id")

  resolved   Boolean   @default(false)
  resolvedAt DateTime?  @map("resolved_at")
  resolvedBy String?    @map("resolved_by") // "auto" | "manual"

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reconciliation_alerts")
}

// ---------------------------------------------------------------------------
// Import tracking
// ---------------------------------------------------------------------------

model Import {
  id               String            @id @default(uuid())
  source           String            // square | chase | doordash | ubereats | grubhub | rocketmoney | manual
  fileName         String            @map("file_name")
  importedAt       DateTime          @default(now()) @map("imported_at")
  rowsProcessed    Int               @default(0) @map("rows_processed")
  rowsFailed       Int               @default(0) @map("rows_failed")
  status           String            @default("pending") // pending | processing | completed | failed
  errorMessage     String?           @map("error_message")
  transactions     Transaction[]
  platformOrders   PlatformOrder[]
  expenses         Expense[]
  payouts          Payout[]
  bankTransactions BankTransaction[]

  // Duplicate detection
  fileHash       String?   @map("file_hash")      // SHA256 of file contents
  dateRangeStart DateTime? @map("date_range_start")
  dateRangeEnd   DateTime? @map("date_range_end")
  duplicateOf    String?   @map("duplicate_of")    // ID of duplicate import if detected
  rowsSkipped    Int       @default(0) @map("rows_skipped") // rows skipped due to dedup

  @@map("imports")
}

// ---------------------------------------------------------------------------
// Expense categorization
// ---------------------------------------------------------------------------

model ExpenseCategory {
  id       String  @id @default(uuid())
  name     String  @unique
  parentId String? @map("parent_id")
  parent   ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ExpenseCategory[] @relation("CategoryHierarchy")
  color    String? // hex color for UI
  icon     String? // emoji or icon name
  expenses Expense[]
  rules    CategorizationRule[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("expense_categories")
}

model CategorizationRule {
  id         String @id @default(uuid())
  type       String // vendor_match | keyword_match | description_match
  pattern    String // match pattern (exact name for vendor_match, regex for others)
  categoryId String @map("category_id")
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])
  priority   Int    @default(0) // higher = checked first
  createdFrom String @default("manual") @map("created_from") // "manual" | "auto_learned"
  hitCount   Int    @default(0) @map("hit_count") // how many times this rule matched
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("categorization_rules")
}

// ---------------------------------------------------------------------------
// Vendor aliases — pattern-based vendor name cleanup & grouping
// ---------------------------------------------------------------------------

model VendorAlias {
  id          String   @id @default(uuid())
  pattern     String   // text to match against vendor name
  matchType   String   @map("match_type") // contains | starts_with | exact
  displayName String   @map("display_name") // clean name to show
  autoCreated Boolean  @default(false) @map("auto_created")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vendor_aliases")
}

// ---------------------------------------------------------------------------
// Closed days (excluded from analytics averages)
// ---------------------------------------------------------------------------

model ClosedDay {
  id           String   @id @default(uuid())
  date         DateTime @unique
  reason       String?
  autoDetected Boolean  @default(false) @map("auto_detected")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("closed_days")
}

// ---------------------------------------------------------------------------
// Audit log
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")  // transaction | expense | payout | bankTransaction
  entityId   String   @map("entity_id")
  field      String   // which field was changed
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  reason     String?  // user-provided reason for the change
  actor      String   @default("user") // "user" | "system" | "auto"
  createdAt  DateTime @default(now()) @map("created_at")

  // Optional FK to transaction
  transactionId String?      @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@map("audit_logs")
}
